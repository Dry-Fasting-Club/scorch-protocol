# ============================================================
# Scorch Protocol — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Neon PostgreSQL ──────────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://neondb_owner:password@ep-xxx-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Admin JWT Secret ─────────────────────────────────────────
# Must be a cryptographically random 64-char hex string.
# Generated value (change this before using in production):
# cd514cd55737f7dece93d0ceee6fff52c6bb34c94ca948085d82edef8d4a9ad6
# Regenerate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=REPLACE_WITH_YOUR_OWN_64_CHAR_HEX

# ── Stripe ───────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Get from: Stripe → Developers → Webhooks → your endpoint → Signing secret
# (Set up AFTER first deploy — endpoint URL must exist first)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cloudflare R2 ────────────────────────────────────────────
# Account ID: visible in URL when logged into Cloudflare dashboard
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
# API Token: Cloudflare → R2 → Manage R2 API Tokens → Create API Token
# Permissions: Object Read & Write on bucket scorch-content
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=scorch-content

# ── hCaptcha ─────────────────────────────────────────────────
# Get from: https://dashboard.hcaptcha.com → Sites → Add Site
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key

# ── Brevo (optional — email marketing) ───────────────────────
# Get from: https://app.brevo.com → API Keys
# If not set, email captures are stored in DB only (still works).
BREVO_API_KEY=xkeysib-...
# The numeric ID of your contact list in Brevo (e.g. "3")
BREVO_LIST_ID=3
